# The variables added in this file are only available locally in MiniOxygen.
SESSION_SECRET="foobar"
PUBLIC_STOREFRONT_API_TOKEN="3c3be56badf93e15951ea9103bd5a78c"
PUBLIC_STORE_DOMAIN="hw-storefront-ui.myshopify.com"
PUBLIC_STOREFRONT_ID="hw-storefront-ui"
PUBLIC_CHECKOUT_DOMAIN="hw-storefront-ui.myshopify.com"
# Customer Account API — find these in Shopify Admin > Headless channel > Customer Account API settings
# CLIENT_ID: Credentials section > copy the Client ID
# API_URL: Application endpoints section (typically https://shopify.com/<shop-id>)
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID="ac69523f-e849-490a-b22f-49d7a6920a4a"
PUBLIC_CUSTOMER_ACCOUNT_API_URL="https://shopify.com/79356526823/account"
SHOP_ID="79356526823"
# Local dev tunnel — ngrok static domain for Customer Account API OAuth (doesn't support localhost)
# Run: ngrok http --domain=<your-static-domain> 5130
# Then configure in Headless channel > Customer Account API > Application setup:
#   Callback URI: https://<domain>/account/authorize
#   JavaScript origin: https://<domain>
#   Logout URI: https://<domain>
DEV_TUNNEL_DOMAIN="alfredia-prebudgetary-nonperceptibly.ngrok-free.dev"

# Payment gateway — 'payfast' for PayFast (dev + prod); 'shopify' to use Shopify native checkout
PUBLIC_PAYMENT_GATEWAY="payfast"

# hw-storefront-ui backend URL (for PayFast payment initiation)
# Use https://app.hoseworld.store when testing via Cloudflare tunnel
# Use http://localhost:3458 only for direct local-to-local calls
STOREFRONT_UI_API_URL="https://app.hoseworld.store"

# Shared secret for internal API calls between storefront and hw-storefront-ui
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="093f74c8ef60b141ef302b27a0f666dcf1ceb64dc9f8f5996628228d6b2a98f4"

# Shared secret for customer invoice email requests (must match INVOICE_API_SECRET in hw-storefront-ui/.env)
INVOICE_API_SECRET="946a1d35300d9dc399b280397cf5f1ac453006589dc80f4e1aaa9e6aac010488"