{
  "name": "hw-hydrogen-storefront",
  "private": true,
  "sideEffects": false,
  "version": "2026.1.15",
  "type": "module",
  "scripts": {
    "build": "react-router typegen && react-router build",
    "dev": "cross-env NODE_ENV=development tsx watch server.ts",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "typecheck": "react-router typegen && tsc --noEmit",
    "codegen": "shopify hydrogen codegen && react-router typegen",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "report:missing-images": "node scripts/generate-missing-images-report.mjs"
  },
  "prettier": "@shopify/prettier-config",
  "dependencies": {
    "@react-router/express": "^7.16.0",
    "@react-router/node": "^7.16.0",
    "@shopify/hydrogen": "^2026.4.3",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.22",
    "morgan": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.16.0",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@graphql-codegen/cli": "5.0.2",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.16.0",
    "@react-router/fs-routes": "^7.16.0",
    "@shopify/cli": "3.85.4",
    "@shopify/hydrogen-codegen": "0.3.3",
    "@shopify/prettier-config": "^1.1.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/eslint": "^9.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "graphql-config": "^5.0.3",
    "happy-dom": "^20.10.2",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vite": "^6.2.4",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^22 || ^24"
  }
}
